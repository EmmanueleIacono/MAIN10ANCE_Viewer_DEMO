# Runtime
NODE_ENV=development
PORT=3000
DEV_PLACEHOLDER=true

# Auth and cookies
COOKIE_SECRET=replace-with-a-long-random-secret
SESSION_MAX_AGE_MS=604800000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Role levels
LIVELLO_2=lv2_ops
LIVELLO_3=lv3_ops
LIVELLO_4=lv4_ops

# PostgreSQL
MAIN10ANCE_DB=postgresql://user:password@localhost:5432/db_name
DATA_SCHEMA=data
UTILITY_SCHEMA=utils

# Autodesk Platform Services / Forge
FORGE_CLIENT_ID=replace-with-forge-client-id
FORGE_CLIENT_SECRET=replace-with-forge-client-secret
FORGE_CALLBACK_URL=http://localhost:3000/api/forge/callback/oauth

# Supabase storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=replace-with-supabase-service-or-anon-key

# Uploads
MAX_UPLOAD_BYTES=20971520
