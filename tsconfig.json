{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "start.js",
    "config.ts",
    "supabase_config.ts",
    "types/**/*.ts",
    "routes/**/*.js",
    "routes/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "client",
    "client/**",
    "dist"
  ]
}
